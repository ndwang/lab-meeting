# The server fails fast if DATABASE_URL, LAB_MEETING_TOKEN, or PORT is missing.
# ANTHROPIC_API_KEY (Q&A) and LAB_MEETING_URL (reporter/poller) are read elsewhere.

# Shared bearer token guarding the ingest endpoints.
# The deployed server and the local sprint runner must agree on this value.
LAB_MEETING_TOKEN=change-me-to-a-long-random-string

# Postgres connection string.
DATABASE_URL=postgres://user:pass@host:5432/lab_meeting

# Anthropic API key for the server-side grounded Q&A agent (Sprint 3+).
ANTHROPIC_API_KEY=

# Port the server listens on (Render sets this automatically in production).
PORT=3000

# Deployed app URL — the reporter agent and the local poller POST here.
LAB_MEETING_URL=https://lab-meeting.onrender.com
